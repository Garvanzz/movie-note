{
    "$schema":  "https://raw.githubusercontent.com/nicedoc/tauri/main/tooling/cli/schema.json",
    "productName":  "Movie Note",
    "version":  "0.1.0",
    "identifier":  "com.movie-note.app",
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.ico",
                                "icons/icon.png"
                            ]
               },
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Movie Note",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  960,
                                    "minHeight":  600,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  [
                                                                     "$APPDATA/images/**",
                                                                     "$APPDATA/workspaces/**"
                                                                 ]
                                                   },
                                 "csp":  null
                             }
            },
    "plugins":  {
                    "shell":  {
                                  "open":  true
                              }
                }
}
